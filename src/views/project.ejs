<%- include('partials/header') %>

    <main>
        <h1>
            <%= project.title %>
        </h1>

        <p>
            <strong>Description:</strong><br>
            <%= project.description %>
        </p>

        <p>
            <strong>Date:</strong><br>
            <%= new Date(project.date).toDateString() %>
        </p>

        <p>
            <strong>Location:</strong><br>
            <%= project.location %>
        </p>

        <p>
            <strong>Organization:</strong><br>
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <p>
            <strong>Categories:</strong><br>
            <% if (categories && categories.length> 0) { %>
                <% categories.forEach(category=> { %>
                    <a href="/category/<%= category.category_id %>" class="category-tag">
                        <%= category.category_name %>
                    </a>
                    <% }); %>
                        <% } else { %>
                            No categories assigned.
                            <% } %>
        </p>
        <% if (user && user.role_name==='admin' ) { %>
            <a href="/assign-categories/<%= project.project_id %>" class="edit-link">Edit Categories</a>
        <% } %>

        <% if (user && user.role_name==='admin' ) { %>
            <a href="/edit-project/<%= project.project_id %>" class="edit-link">Edit Project</a>
        <% } %>

    </main>

    <%- include('partials/footer') %>